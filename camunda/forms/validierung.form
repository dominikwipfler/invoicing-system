{
  "id": "validierung",
  "schemaVersion": 12,
  "exporter": {
    "name": "Camunda Forms",
    "version": "0.12.0"
  },
  "type": "default",
  "components": [
    {
      "type": "text",
      "id": "Text_Header",
      "text": "### Rechnung prüfen und validieren\nBitte vergleichen Sie die erfassten Rechnungsdaten mit dem Originaldokument unten und treffen Sie eine Entscheidung."
    },
    {
      "type": "text",
      "id": "Text_Zusammenfassung",
      "text": "**Rechnungsübersicht**\n- Rechnungs-ID: `{{invoiceId}}`\n- Lieferant: `{{supplierName}}`\n- Rechnungsnummer: `{{invoiceNumber}}`\n- Betrag: `{{amountEuro}} €`\n- Datum: `{{invoiceDate}}`\n- ERP-Referenz: `{{erpReferenzNummer}}`"
    },
    {
      "type": "image",
      "id": "Image_PDFPreview",
      "source": "=pdfImageDataUri",
      "alt": "Originaldokument"
    },
    {
      "type": "radio",
      "id": "Field_validierungErgebnis",
      "key": "validierungErgebnis",
      "label": "Entscheidung",
      "validate": {
        "required": true
      },
      "values": [
        { "label": "Freigabe erteilen — Prozess fortsetzen",        "value": "genehmigt" },
        { "label": "Info beim Lieferanten anfragen (erst danach freigeben)", "value": "info" },
        { "label": "Rechnung ablehnen — Prozess beenden",            "value": "abgelehnt" }
      ]
    },
    {
      "type": "textfield",
      "id": "Field_freigebenderName",
      "key": "freigebenderName",
      "label": "Ihr Name (Prüfende Person)",
      "validate": {
        "required": true
      }
    },
    {
      "type": "textarea",
      "id": "Field_freigabeKommentar",
      "key": "freigabeKommentar",
      "label": "Begründung / Kommentar (Pflicht bei Ablehnung oder Rückfrage)"
    }
  ]
}
