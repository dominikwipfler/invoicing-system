{
  "id": "compliance-check",
  "schemaVersion": 12,
  "exporter": {
    "name": "Camunda Forms",
    "version": "0.12.0"
  },
  "type": "default",
  "components": [
    {
      "type": "text",
      "id": "Text_Header",
      "text": "### Compliance Check\nDie Rechnung überschreitet den Compliance-Schwellenwert von 10.000 €. Bitte prüfen Sie die Rechnung und erteilen Sie die Compliance-Freigabe.\n\n📄 [Original-Rechnung als PDF anzeigen](http://localhost:4000/invoices/test-invoice.pdf)"
    },
    {
      "type": "text",
      "id": "Text_Zusammenfassung",
      "text": "**Rechnungsübersicht**\n- Rechnungs-ID: `{{invoiceId}}`\n- Lieferant: `{{supplierName}}`\n- Rechnungsnummer: `{{invoiceNumber}}`\n- Betrag: `{{amountEuro}} €`\n- Datum: `{{invoiceDate}}`"
    },
    {
      "type": "radio",
      "id": "Field_freigabeEntscheidung",
      "key": "freigabeEntscheidung",
      "label": "Entscheidung",
      "validate": {
        "required": true
      },
      "values": [
        { "label": "Compliance-Freigabe erteilen", "value": "genehmigt" },
        { "label": "Compliance abgelehnt — Prozess beenden", "value": "abgelehnt" }
      ]
    },
    {
      "type": "textfield",
      "id": "Field_freigebenderName",
      "key": "freigebenderName",
      "label": "Ihr Name (Compliance Officer)",
      "validate": {
        "required": true
      }
    },
    {
      "type": "textarea",
      "id": "Field_freigabeKommentar",
      "key": "freigabeKommentar",
      "label": "Begründung / Kommentar (Pflicht bei Ablehnung)"
    }
  ]
}
