{
  "id": "ki-pruefung",
  "schemaVersion": 12,
  "exporter": {
    "name": "Camunda Forms",
    "version": "0.12.0"
  },
  "type": "default",
  "components": [
    {
      "type": "text",
      "id": "Text_Header",
      "text": "### KI-Extraktion prüfen und korrigieren\nDie KI hat die folgenden Rechnungsdaten aus dem PDF extrahiert. Bitte prüfen Sie die Werte und korrigieren Sie sie bei Bedarf. Die KI-Konfidenz war unter dem Schwellenwert von 80%."
    },
    {
      "type": "number",
      "id": "Field_aiConfidence",
      "key": "aiConfidence",
      "label": "KI-Konfidenz (automatisch ermittelt, 0–1)",
      "disabled": true,
      "decimalDigits": 2,
      "serializeToString": false
    },
    {
      "type": "text",
      "id": "Text_Divider",
      "text": "---\n**Bitte überprüfen und ggf. korrigieren:**"
    },
    {
      "type": "textfield",
      "id": "Field_supplierName",
      "key": "supplierName",
      "label": "Lieferant / Rechnungssteller *",
      "validate": {
        "required": true,
        "minLength": 2
      }
    },
    {
      "type": "textfield",
      "id": "Field_invoiceNumber",
      "key": "invoiceNumber",
      "label": "Rechnungsnummer *",
      "validate": {
        "required": true
      }
    },
    {
      "type": "number",
      "id": "Field_amountEuro",
      "key": "amountEuro",
      "label": "Rechnungsbetrag inkl. MwSt (€) *",
      "validate": {
        "required": true,
        "min": 0.01
      },
      "decimalDigits": 2,
      "increment": "0.01",
      "serializeToString": false
    },
    {
      "type": "datetime",
      "id": "Field_invoiceDate",
      "key": "invoiceDate",
      "label": "Rechnungsdatum *",
      "subtype": "date",
      "dateLabel": "Datum wählen",
      "validate": {
        "required": true
      }
    },
    {
      "type": "select",
      "id": "Field_eingangskanal",
      "key": "eingangskanal",
      "label": "Eingangskanal",
      "validate": {
        "required": true
      },
      "values": [
        { "label": "E-Mail", "value": "email" },
        { "label": "Post / Brief", "value": "post" },
        { "label": "EDI (automatisch)", "value": "edi" },
        { "label": "Sonstige", "value": "sonstige" }
      ]
    },
    {
      "type": "textarea",
      "id": "Field_notizen",
      "key": "notizen",
      "label": "Bemerkungen / Korrekturen (optional)"
    }
  ]
}
