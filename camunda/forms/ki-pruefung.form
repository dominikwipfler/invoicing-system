{
  "id": "ki-pruefung",
  "schemaVersion": 12,
  "exporter": {
    "name": "Camunda Forms",
    "version": "0.12.0"
  },
  "type": "default",
  "components": [
    {
      "type": "text",
      "id": "Text_Header",
      "text": "### KI-Extraktion prüfen und korrigieren\nDie KI hat die folgenden Rechnungsdaten aus dem PDF extrahiert. Bitte vergleichen Sie die Werte links mit dem Originaldokument rechts und korrigieren Sie sie bei Bedarf. Die KI-Konfidenz war unter dem Schwellenwert von 80%."
    },
    {
      "type": "group",
      "id": "Group_Fields",
      "label": "Rechnungsdaten (bearbeitbar)",
      "showOutline": true,
      "layout": { "row": "Row_MainSplit", "columns": 8 },
      "components": [
        {
          "type": "textfield",
          "id": "Field_supplierName",
          "key": "supplierName",
          "label": "Lieferant *",
          "validate": { "required": true, "minLength": 2 }
        },
        {
          "type": "textfield",
          "id": "Field_invoiceNumber",
          "key": "invoiceNumber",
          "label": "Rechnungsnummer *",
          "validate": { "required": true }
        },
        {
          "type": "number",
          "id": "Field_amountEuro",
          "key": "amountEuro",
          "label": "Betrag (€) *",
          "validate": { "required": true, "min": 0.01 },
          "decimalDigits": 2,
          "increment": "0.01",
          "serializeToString": false
        },
        {
          "type": "datetime",
          "id": "Field_invoiceDate",
          "key": "invoiceDate",
          "label": "Rechnungsdatum *",
          "subtype": "date",
          "dateLabel": "Datum wählen",
          "validate": { "required": true }
        },
        {
          "type": "number",
          "id": "Field_aiConfidence",
          "key": "aiConfidence",
          "label": "KI-Konfidenz (0–1)",
          "disabled": true,
          "decimalDigits": 2,
          "serializeToString": false
        },
        {
          "type": "select",
          "id": "Field_eingangskanal",
          "key": "eingangskanal",
          "label": "Eingangskanal",
          "validate": { "required": true },
          "values": [
            { "label": "E-Mail", "value": "email" },
            { "label": "Post / Brief", "value": "post" },
            { "label": "EDI (automatisch)", "value": "edi" },
            { "label": "Sonstige", "value": "sonstige" }
          ]
        },
        {
          "type": "textarea",
          "id": "Field_notizen",
          "key": "notizen",
          "label": "Bemerkungen (optional)"
        }
      ]
    },
    {
      "type": "group",
      "id": "Group_Preview",
      "label": "Originaldokument",
      "showOutline": true,
      "layout": { "row": "Row_MainSplit", "columns": 8 },
      "components": [
        {
          "type": "image",
          "id": "Image_PDFPreview",
          "source": "=pdfImageDataUri",
          "alt": "Originaldokument"
        }
      ]
    }
  ]
}
