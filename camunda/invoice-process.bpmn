      <bpmndi:BPMNEdge id="e17" bpmnElement="Flow_GWInfo_Request">
        <di:waypoint x="1990" y="365"/>
        <di:waypoint x="1990" y="400"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1996" y="375" width="9" height="14"/></bpmndi:BPMNLabel>
