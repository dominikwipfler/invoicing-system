      <bpmndi:BPMNShape id="s_Comply"      bpmnElement="Task_Compliance"><dc:Bounds x="2100" y="720" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_GWCompDec"   bpmnElement="GW_ComplianceDecision" isMarkerVisible="true">
