<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
  id="Definitions_SollProzess_Sprint4"
  targetNamespace="http://bpmn.io/schema/bpmn"
  exporter="Camunda Web Modeler"
  exporterVersion="c70c064"
  modeler:executionPlatform="Camunda Cloud"
  modeler:executionPlatformVersion="8.9.0">

  <bpmn:error id="Error_GRPC"    name="gRPC Fehler"    errorCode="GRPC_ERROR"/>
  <bpmn:error id="Error_Payment" name="Zahlungsfehler" errorCode="PAYMENT_ERROR"/>
  <bpmn:message id="Msg_Email"   name="RechnungPerEmail"/>

  <bpmn:collaboration id="Collaboration_InvoiceProcess">
    <bpmn:participant id="Participant_Process"
                      name="Eingangsrechnungsverarbeitung (Sprint 4)"
                      processRef="Process_Invoice"/>
  </bpmn:collaboration>

  <bpmn:process id="Process_Invoice" isExecutable="true">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_System" name="System">
        <bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Receive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_gRPC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Payment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Archive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Fehler</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Clerk" name="Sachbearbeiter">
        <bpmn:flowNodeRef>Task_Register</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Fehlerkorrektur</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_EnterDataNeeded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Join1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_ValidateJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Validate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_ComplianceNeeded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Join2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_InfoNeeded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RequestInfo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReceiveInfo</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_DataEntry" name="Datenerfassung">
        <bpmn:flowNodeRef>Task_EnterData</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EnterERP</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Finance" name="Finanzabteilung">
        <bpmn:flowNodeRef>Task_Compliance</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Manager" name="Manager">
        <bpmn:flowNodeRef>Task_Approve</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- START: E-Mail -->
    <bpmn:startEvent id="Start_1" name="Rechnung per&#10;E-Mail eingegangen">
      <bpmn:outgoing>Flow_Start_Receive</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- System: Rechnung empfangen -->
    <bpmn:serviceTask id="Task_Receive" name="Rechnung&#10;empfangen">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="receive-invoice"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_Receive</bpmn:incoming>
      <bpmn:outgoing>Flow_Receive_Register</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Sachbearbeiter: Rechnungsdaten manuell erfassen -->
    <bpmn:userTask id="Task_Register" name="Rechnungsdaten&#10;erfassen">
      <bpmn:extensionElements>
        <zeebe:userTask/>
        <zeebe:formDefinition formId="rechnungserfassung"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Receive_Register</bpmn:incoming>
      <bpmn:incoming>Flow_Fehlerkorrektur_Register</bpmn:incoming>
      <bpmn:outgoing>Flow_Register_gRPC</bpmn:outgoing>
    </bpmn:userTask>

    <!-- System: Metadaten per gRPC speichern -->
    <bpmn:serviceTask id="Task_gRPC" name="Metadaten per&#10;gRPC speichern">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="grpc-save-invoice"/>
        <zeebe:ioMapping>
          <zeebe:input source="=invoiceId"     target="invoiceId"/>
          <zeebe:input source="=supplierName"  target="supplierName"/>
          <zeebe:input source="=invoiceNumber" target="invoiceNumber"/>
          <zeebe:input source="=amountEuro"    target="amountEuro"/>
          <zeebe:input source="=invoiceDate"   target="invoiceDate"/>
          <zeebe:output source="=grpcSuccess"  target="grpcSuccess"/>
          <zeebe:output source="=amountCents"  target="amountCents"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Register_gRPC</bpmn:incoming>
      <bpmn:outgoing>Flow_gRPC_GW1</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Boundary: gRPC Fehler -->
    <bpmn:boundaryEvent id="Boundary_gRPCFehler" attachedToRef="Task_gRPC" cancelActivity="true">
      <bpmn:outgoing>Flow_Boundary_Fehler</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_GRPC"/>
    </bpmn:boundaryEvent>

    <!-- Sachbearbeiter: Fehlerkorrektur -->
    <bpmn:userTask id="Task_Fehlerkorrektur" name="gRPC-Fehler prüfen&#10;und Daten korrigieren">
      <bpmn:extensionElements>
        <zeebe:userTask/>
        <zeebe:formDefinition formId="rechnungserfassung"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Boundary_Fehler</bpmn:incoming>
      <bpmn:outgoing>Flow_Fehlerkorrektur_Register</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Gateway: Daten vollständig? -->
    <bpmn:exclusiveGateway id="GW_EnterDataNeeded" name="Daten&#10;vollständig?" default="Flow_GW1_Enter">
      <bpmn:incoming>Flow_gRPC_GW1</bpmn:incoming>
      <bpmn:outgoing>Flow_GW1_Skip</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW1_Enter</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Datenerfassung: Fehlende Daten ergänzen -->
    <bpmn:userTask id="Task_EnterData" name="Fehlende&#10;Rechnungsdaten ergänzen">
      <bpmn:extensionElements>
        <zeebe:userTask/>
        <zeebe:formDefinition formId="rechnungserfassung"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_GW1_Enter</bpmn:incoming>
      <bpmn:outgoing>Flow_Enter_Join1</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_Join1">
      <bpmn:incoming>Flow_GW1_Skip</bpmn:incoming>
      <bpmn:incoming>Flow_Enter_Join1</bpmn:incoming>
      <bpmn:outgoing>Flow_Join1_ValidateJoin</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="GW_ValidateJoin">
      <bpmn:incoming>Flow_Join1_ValidateJoin</bpmn:incoming>
      <bpmn:incoming>Flow_ReceiveInfo_ValidateJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_ValidateJoin_Validate</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Sachbearbeiter: Rechnung prüfen -->
    <bpmn:userTask id="Task_Validate" name="Rechnung&#10;prüfen und validieren">
      <bpmn:extensionElements>
        <zeebe:userTask/>
        <zeebe:formDefinition formId="freigabe"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ValidateJoin_Validate</bpmn:incoming>
      <bpmn:outgoing>Flow_Validate_GW2</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Gateway: Compliance Check nötig? -->
    <bpmn:exclusiveGateway id="GW_ComplianceNeeded" name="Compliance&#10;Check nötig?" default="Flow_GW2_Skip">
      <bpmn:incoming>Flow_Validate_GW2</bpmn:incoming>
      <bpmn:outgoing>Flow_GW2_Check</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW2_Skip</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Finanzabteilung: Compliance Check -->
    <bpmn:userTask id="Task_Compliance" name="Compliance&#10;Check">
      <bpmn:extensionElements>
        <zeebe:userTask/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_GW2_Check</bpmn:incoming>
      <bpmn:outgoing>Flow_Compliance_Join2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_Join2">
      <bpmn:incoming>Flow_GW2_Skip</bpmn:incoming>
      <bpmn:incoming>Flow_Compliance_Join2</bpmn:incoming>
      <bpmn:outgoing>Flow_Join2_GW3</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Gateway: Info vom Lieferanten nötig? -->
    <bpmn:exclusiveGateway id="GW_InfoNeeded" name="Info vom&#10;Lieferanten nötig?" default="Flow_GW3_Skip">
      <bpmn:incoming>Flow_Join2_GW3</bpmn:incoming>
      <bpmn:outgoing>Flow_GW3_Request</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW3_Skip</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Sachbearbeiter: Info anfordern -->
    <bpmn:task id="Task_RequestInfo" name="Info beim&#10;Lieferanten anfragen">
      <bpmn:incoming>Flow_GW3_Request</bpmn:incoming>
      <bpmn:outgoing>Flow_Request_Receive</bpmn:outgoing>
    </bpmn:task>

    <!-- Sachbearbeiter: Info erhalten -->
    <bpmn:userTask id="Task_ReceiveInfo" name="Info vom&#10;Lieferanten erhalten">
      <bpmn:extensionElements>
        <zeebe:userTask/>
        <zeebe:formDefinition formId="UserTaskForm_ReceiveInfo"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Request_Receive</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveInfo_ValidateJoin</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Manager: Rechnung freigeben -->
    <bpmn:userTask id="Task_Approve" name="Rechnung&#10;freigeben">
      <bpmn:extensionElements>
        <zeebe:userTask/>
        <zeebe:formDefinition formId="freigabe"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_GW3_Skip</bpmn:incoming>
      <bpmn:outgoing>Flow_Approve_ERP</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Datenerfassung: ERP-Erfassung (Sprint 5: automatisch per RPA) -->
    <bpmn:serviceTask id="Task_EnterERP" name="Rechnungsdaten ins&#10;ERP System eingeben (RPA)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="rpa-erp-entry"/>
        <zeebe:ioMapping>
          <zeebe:input source="=invoiceId"     target="invoiceId"/>
          <zeebe:input source="=supplierName"  target="supplierName"/>
          <zeebe:input source="=invoiceNumber" target="invoiceNumber"/>
          <zeebe:input source="=amountEuro"    target="amountEuro"/>
          <zeebe:input source="=invoiceDate"   target="invoiceDate"/>
          <zeebe:output source="=erpReferenzNummer" target="erpReferenzNummer"/>
          <zeebe:output source="=erpErfasst"   target="erpErfasst"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Approve_ERP</bpmn:incoming>
      <bpmn:outgoing>Flow_ERP_Payment</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- System: Zahlung via RabbitMQ (automatisch) -->
    <bpmn:serviceTask id="Task_Payment" name="Zahlung an&#10;Zahlungssystem senden">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="rabbitmq-payment"/>
        <zeebe:ioMapping>
          <zeebe:input source="=invoiceId"         target="invoiceId"/>
          <zeebe:input source="=supplierName"      target="supplierName"/>
          <zeebe:input source="=amountCents"       target="amountCents"/>
          <zeebe:output source="=paymentTriggered" target="paymentTriggered"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ERP_Payment</bpmn:incoming>
      <bpmn:outgoing>Flow_Payment_Archive</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Boundary: RabbitMQ Fehler -->
    <bpmn:boundaryEvent id="Boundary_PaymentFehler" attachedToRef="Task_Payment" cancelActivity="true">
      <bpmn:outgoing>Flow_Payment_Fehler</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_Payment"/>
    </bpmn:boundaryEvent>

    <!-- System: Archivieren -->
    <bpmn:serviceTask id="Task_Archive" name="Rechnung&#10;archivieren">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="archive-invoice"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Payment_Archive</bpmn:incoming>
      <bpmn:outgoing>Flow_Archive_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- END EVENTS -->
    <bpmn:endEvent id="End_1" name="Rechnung&#10;verarbeitet">
      <bpmn:incoming>Flow_Archive_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="End_Fehler" name="Zahlung&#10;fehlgeschlagen">
      <bpmn:incoming>Flow_Payment_Fehler</bpmn:incoming>
    </bpmn:endEvent>

    <!-- SEQUENCE FLOWS -->
    <bpmn:sequenceFlow id="Flow_Start_Receive"            sourceRef="Start_1"              targetRef="Task_Receive"/>
    <bpmn:sequenceFlow id="Flow_Receive_Register"         sourceRef="Task_Receive"         targetRef="Task_Register"/>
    <bpmn:sequenceFlow id="Flow_Register_gRPC"            sourceRef="Task_Register"        targetRef="Task_gRPC"/>
    <bpmn:sequenceFlow id="Flow_Boundary_Fehler"          sourceRef="Boundary_gRPCFehler"  targetRef="Task_Fehlerkorrektur"/>
    <bpmn:sequenceFlow id="Flow_Fehlerkorrektur_Register" sourceRef="Task_Fehlerkorrektur" targetRef="Task_Register"/>
    <bpmn:sequenceFlow id="Flow_gRPC_GW1"                 sourceRef="Task_gRPC"            targetRef="GW_EnterDataNeeded"/>
    <bpmn:sequenceFlow id="Flow_GW1_Skip" name="ja"       sourceRef="GW_EnterDataNeeded"   targetRef="GW_Join1">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=dataComplete = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_GW1_Enter" name="nein"    sourceRef="GW_EnterDataNeeded"   targetRef="Task_EnterData"/>
    <bpmn:sequenceFlow id="Flow_Enter_Join1"              sourceRef="Task_EnterData"        targetRef="GW_Join1"/>
    <bpmn:sequenceFlow id="Flow_Join1_ValidateJoin"       sourceRef="GW_Join1"              targetRef="GW_ValidateJoin"/>
    <bpmn:sequenceFlow id="Flow_ValidateJoin_Validate"    sourceRef="GW_ValidateJoin"       targetRef="Task_Validate"/>
    <bpmn:sequenceFlow id="Flow_Validate_GW2"             sourceRef="Task_Validate"         targetRef="GW_ComplianceNeeded"/>
    <bpmn:sequenceFlow id="Flow_GW2_Check" name="ja"      sourceRef="GW_ComplianceNeeded"   targetRef="Task_Compliance">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=complianceNeeded = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_GW2_Skip" name="nein"     sourceRef="GW_ComplianceNeeded"   targetRef="GW_Join2"/>
    <bpmn:sequenceFlow id="Flow_Compliance_Join2"         sourceRef="Task_Compliance"        targetRef="GW_Join2"/>
    <bpmn:sequenceFlow id="Flow_Join2_GW3"                sourceRef="GW_Join2"               targetRef="GW_InfoNeeded"/>
    <bpmn:sequenceFlow id="Flow_GW3_Request" name="ja"    sourceRef="GW_InfoNeeded"          targetRef="Task_RequestInfo">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=infoNeeded = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_GW3_Skip" name="nein"     sourceRef="GW_InfoNeeded"          targetRef="Task_Approve"/>
    <bpmn:sequenceFlow id="Flow_Request_Receive"          sourceRef="Task_RequestInfo"        targetRef="Task_ReceiveInfo"/>
    <bpmn:sequenceFlow id="Flow_ReceiveInfo_ValidateJoin" sourceRef="Task_ReceiveInfo"        targetRef="GW_ValidateJoin"/>
    <bpmn:sequenceFlow id="Flow_Approve_ERP"              sourceRef="Task_Approve"            targetRef="Task_EnterERP"/>
    <bpmn:sequenceFlow id="Flow_ERP_Payment"              sourceRef="Task_EnterERP"           targetRef="Task_Payment"/>
    <bpmn:sequenceFlow id="Flow_Payment_Archive"          sourceRef="Task_Payment"            targetRef="Task_Archive"/>
    <bpmn:sequenceFlow id="Flow_Payment_Fehler"           sourceRef="Boundary_PaymentFehler"  targetRef="End_Fehler"/>
    <bpmn:sequenceFlow id="Flow_Archive_End"              sourceRef="Task_Archive"            targetRef="End_1"/>

  </bpmn:process>

  <!-- LAYOUT -->
  <bpmndi:BPMNDiagram id="Diagram_1">
    <bpmndi:BPMNPlane id="Plane_1" bpmnElement="Collaboration_InvoiceProcess">

      <bpmndi:BPMNShape id="Participant_di" bpmnElement="Participant_Process" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="2160" height="900"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_System_di"    bpmnElement="Lane_System"    isHorizontal="true"><dc:Bounds x="190" y="80"  width="2130" height="160"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Clerk_di"     bpmnElement="Lane_Clerk"     isHorizontal="true"><dc:Bounds x="190" y="240" width="2130" height="280"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_DataEntry_di" bpmnElement="Lane_DataEntry" isHorizontal="true"><dc:Bounds x="190" y="520" width="2130" height="150"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Finance_di"   bpmnElement="Lane_Finance"   isHorizontal="true"><dc:Bounds x="190" y="670" width="2130" height="130"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Manager_di"   bpmnElement="Lane_Manager"   isHorizontal="true"><dc:Bounds x="190" y="800" width="2130" height="180"/></bpmndi:BPMNShape>

      <!-- Shapes -->
      <bpmndi:BPMNShape id="s_Start"    bpmnElement="Start_1"><dc:Bounds x="242" y="142" width="36" height="36"/><bpmndi:BPMNLabel><dc:Bounds x="218" y="186" width="84" height="27"/></bpmndi:BPMNLabel></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_Receive"  bpmnElement="Task_Receive"><dc:Bounds x="330" y="120" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_Register" bpmnElement="Task_Register"><dc:Bounds x="510" y="300" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_gRPC"     bpmnElement="Task_gRPC"><dc:Bounds x="700" y="120" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_BgRPC"    bpmnElement="Boundary_gRPCFehler"><dc:Bounds x="752" y="182" width="36" height="36"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_Fehler"   bpmnElement="Task_Fehlerkorrektur"><dc:Bounds x="700" y="390" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_GW1"      bpmnElement="GW_EnterDataNeeded" isMarkerVisible="true"><dc:Bounds x="885" y="135" width="50" height="50"/><bpmndi:BPMNLabel><dc:Bounds x="870" y="193" width="80" height="27"/></bpmndi:BPMNLabel></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_Enter"    bpmnElement="Task_EnterData"><dc:Bounds x="870" y="540" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_GWJ1"     bpmnElement="GW_Join1" isMarkerVisible="true"><dc:Bounds x="1055" y="135" width="50" height="50"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_GWVj"     bpmnElement="GW_ValidateJoin" isMarkerVisible="true"><dc:Bounds x="1175" y="135" width="50" height="50"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_Validate" bpmnElement="Task_Validate"><dc:Bounds x="1280" y="300" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_GWComp"   bpmnElement="GW_ComplianceNeeded" isMarkerVisible="true"><dc:Bounds x="1460" y="315" width="50" height="50"/><bpmndi:BPMNLabel><dc:Bounds x="1447" y="373" width="76" height="40"/></bpmndi:BPMNLabel></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_Comply"   bpmnElement="Task_Compliance"><dc:Bounds x="1435" y="690" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_GWJ2"     bpmnElement="GW_Join2" isMarkerVisible="true"><dc:Bounds x="1635" y="315" width="50" height="50"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_GWInfo"   bpmnElement="GW_InfoNeeded" isMarkerVisible="true"><dc:Bounds x="1755" y="315" width="50" height="50"/><bpmndi:BPMNLabel><dc:Bounds x="1744" y="263" width="72" height="40"/></bpmndi:BPMNLabel></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_ReqInfo"  bpmnElement="Task_RequestInfo"><dc:Bounds x="1600" y="400" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_RecvInfo" bpmnElement="Task_ReceiveInfo"><dc:Bounds x="1400" y="400" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_Approve"  bpmnElement="Task_Approve"><dc:Bounds x="1740" y="840" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_ERP"      bpmnElement="Task_EnterERP"><dc:Bounds x="1900" y="540" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_Payment"  bpmnElement="Task_Payment"><dc:Bounds x="1900" y="120" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_BPay"     bpmnElement="Boundary_PaymentFehler"><dc:Bounds x="1952" y="182" width="36" height="36"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_Archive"  bpmnElement="Task_Archive"><dc:Bounds x="2070" y="120" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_End1"     bpmnElement="End_1"><dc:Bounds x="2242" y="142" width="36" height="36"/><bpmndi:BPMNLabel><dc:Bounds x="2222" y="186" width="76" height="27"/></bpmndi:BPMNLabel></bpmndi:BPMNShape>
