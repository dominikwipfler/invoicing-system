# Camunda 8 Self-Managed (Zeebe Gateway)
ZEEBE_ADDRESS=localhost:26500
ZEEBE_GRPC_ADDRESS=grpc://localhost:26500
ZEEBE_REST_ADDRESS=http://localhost:8080

# Alternativ: Camunda SaaS (Cloud)
# ZEEBE_CLIENT_ID=...
# ZEEBE_CLIENT_SECRET=...
# ZEEBE_ADDRESS=...
# CAMUNDA_OAUTH_URL=https://login.cloud.camunda.io/oauth/token
# CAMUNDA_TASKLIST_BASE_URL=https://...
# CAMUNDA_OPERATE_BASE_URL=https://...

# Interne Services
GRPC_ADDRESS=localhost:50051
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# AI Agent (Sprint 6) — Zwei Provider möglich: "n8n" (default) oder "claude"
AI_PROVIDER=n8n
AI_CONFIDENCE_THRESHOLD=0.8

# n8n Webhook (Standard-Provider) — Google Gemini via n8n
N8N_WEBHOOK_URL=https://leonjungkind0909.app.n8n.cloud/webhook/invoice-extract

# Claude API (Alternative Provider) — API Key von https://console.anthropic.com
# Nutze AI_PROVIDER=claude um auf Claude umzuschalten
ANTHROPIC_API_KEY=

# AI Mock-Modus (für Tests ohne API-Aufruf) — Setzt Vorrang vor AI_PROVIDER
AI_MOCK_MODE=false

# UiPath Orchestrator (Sprint 5.3 — optional)
UIPATH_CLIENT_ID=
UIPATH_CLIENT_SECRET=
UIPATH_ORGANIZATION=hkalshnhxm
UIPATH_TENANT=DefaultTenant
UIPATH_FOLDER=Shared
UIPATH_PROCESS_NAME=RPA Workflow
